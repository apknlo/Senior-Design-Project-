String formatTime12FromHourFloat(float hourFloat) {
  while (hourFloat >= 24.0f) hourFloat -= 24.0f;
  while (hourFloat < 0.0f)   hourFloat += 24.0f;

  int h24 = (int)floorf(hourFloat);
  float frac = hourFloat - (float)h24;
  int minutes = (int)lroundf(frac * 60.0f);
  if (minutes >= 60) {
    minutes = 0;
    h24 = (h24 + 1) % 24;
  }

  int h12 = h24 % 12;
  if (h12 == 0) h12 = 12;
  const char* ap = (h24 < 12) ? "AM" : "PM";

  char buf[12];
  snprintf(buf, sizeof(buf), "%d:%02d %s", h12, minutes, ap);
  return String(buf);
}

void updateSimTime12hCloud() {
  simTime12h = formatTime12FromHourFloat(simHour_f);
}

