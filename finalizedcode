// RELAY HELPERS
static inline void setRelayPinRaw(int pin, bool on) {
  if (RELAY_ACTIVE_LOW) digitalWrite(pin, on ? LOW : HIGH);
  else                  digitalWrite(pin, on ? HIGH : LOW);
}

static inline void allRelaysOff() {
  setRelayPinRaw(RELAY1_PIN, false);
  setRelayPinRaw(RELAY2_PIN, false);
}

static unsigned long lastSwitchMs = 0;
static const unsigned long MIN_DWELL_MS_MANUAL = 2500;
static const unsigned long MIN_DWELL_MS_AUTO   = 600;
static const unsigned long BREAK_BEFORE_MAKE_MS = 150;

void applySourceRelaysSafe() {
  unsigned long now = millis();

  bool reqR1 = relay1_on;
  bool reqR2 = relay2_on;

  if (reqR1 && reqR2) {
    reqR2 = false;
    relay2_on = false;
  }

  static bool appliedR1 = false, appliedR2 = false;
  static bool pendingValid = false;
  static bool pendR1 = false, pendR2 = false;

  if (reqR1 != appliedR1 || reqR2 != appliedR2) {
    pendR1 = reqR1;
    pendR2 = reqR2;
    pendingValid = true;
  }

  unsigned long dwell = autoMode ? MIN_DWELL_MS_AUTO : MIN_DWELL_MS_MANUAL;

  if ((now - lastSwitchMs) < dwell) {
    relay1_on = appliedR1;
    relay2_on = appliedR2;
    setRelayPinRaw(RELAY1_PIN, appliedR1);
    setRelayPinRaw(RELAY2_PIN, appliedR2);
    trackAppliedRelays(now, appliedR1, appliedR2);
    return;
  }

  if (!pendingValid) {
    setRelayPinRaw(RELAY1_PIN, appliedR1);
    setRelayPinRaw(RELAY2_PIN, appliedR2);
    relay1_on = appliedR1;
    relay2_on = appliedR2;
    trackAppliedRelays(now, appliedR1, appliedR2);
    return;
  }

  allRelaysOff();
  delay(BREAK_BEFORE_MAKE_MS);

  setRelayPinRaw(RELAY1_PIN, pendR1);
  setRelayPinRaw(RELAY2_PIN, pendR2);

  appliedR1 = pendR1;
  appliedR2 = pendR2;
  relay1_on = appliedR1;
  relay2_on = appliedR2;

  pendingValid = false;
  lastSwitchMs = now;

  trackAppliedRelays(now, appliedR1, appliedR2);
}

// FAN PWM + TACH
static float g_fanAppliedPct = 0.0f;
static bool  g_fanGuard = false;

static inline uint32_t dutyPctToCounts(float pct) {
  pct = clampf(pct, 0.0f, 100.0f);
  const uint32_t maxCounts = (1u << FAN_PWM_RES) - 1u;
  uint32_t counts = (uint32_t)((pct / 100.0f) * maxCounts + 0.5f);
  if (FAN_PWM_INVERT) counts = maxCounts - counts;
  return counts;
}

static void setFanDutyApplied(float appliedPct) {
  g_fanAppliedPct = clampf(appliedPct, 0.0f, 100.0f);
  ledcWrite(FAN_PWM_CH, dutyPctToCounts(g_fanAppliedPct));

  g_fanGuard = true;
  fanDuty_pct = g_fanAppliedPct;
  g_fanGuard = false;
}

void onFanDutyPctChange() {
  if (g_fanGuard) return;
  setFanDutyApplied(fanDuty_pct);
}

