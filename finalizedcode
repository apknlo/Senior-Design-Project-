// DEMAND SHAPE
static float demandFactorByProfile(int hour) {
  if (tariffProfile == 1) {
    if (hour < 8)   return 0.30f;
    if (hour < 13)  return 0.60f;
    if (hour < 16)  return 0.90f;
    if (hour < 21)  return 1.00f;
    return 0.70f;
  } else {
    if (hour < 6)   return 0.40f;
    if (hour < 9)   return 0.90f;
    if (hour < 16)  return 0.30f;
    if (hour < 21)  return 1.00f;
    return 0.50f;
  }
}

// THERMAL PRE-COOL / PRE-HEAT
static float thermalReserve = 0.0f;

static void updateThermalReserve(float simDtHours, float speedFrac) {
  if (simDtHours <= 0) return;

  thermalReserve -= 0.04f * simDtHours;
  if (thermalReserve < 0) thermalReserve = 0;

  const bool peak = isPeakHour(simHour);

  if (tariffProfile == 1) {
    bool pre = (simHour >= 13 && simHour < 16) && !peak;
    if (pre)  thermalReserve += 0.25f * simDtHours * speedFrac;
    if (peak) thermalReserve -= 0.30f * simDtHours * speedFrac;
  } else {
    bool pre = ((simHour >= 6 && simHour < 7) || (simHour >= 16 && simHour < 17)) && !peak;
    if (pre)  thermalReserve += 0.22f * simDtHours * speedFrac;
    if (peak) thermalReserve -= 0.28f * simDtHours * speedFrac;
  }

  thermalReserve = clampf(thermalReserve, 0.0f, 1.0f);
}

// FAN AUTO
static const float FAN_RAMP_PCT_PER_SIM_HOUR = 60.0f;

static float fanTargetAppliedPct(int hour) {
  float baseDemand = demandFactorByProfile(hour);

  if (isPeakHour(hour)) {
    baseDemand = fmaxf(0.20f, baseDemand - 0.45f * thermalReserve);
  }

  bool battLow = (batterySOC_pct < 30.0f);
  if (battLow && isPeakHour(hour)) baseDemand *= 0.80f;

  float minPct = (tariffProfile == 1) ? 15.0f : 20.0f;
  float maxPct = 95.0f;

  if (tariffProfile == 1 && hour == 15) baseDemand = fmaxf(baseDemand, 0.95f);
  if (tariffProfile == 0 && hour == 6)  baseDemand = fmaxf(baseDemand, 0.85f);

  return minPct + clampf(baseDemand, 0.0f, 1.0f) * (maxPct - minPct);
}

static void updateFanAuto(float simDtHours) {
  if (!autoMode) return;

  float target = fanTargetAppliedPct(simHour);
  float maxStep = FAN_RAMP_PCT_PER_SIM_HOUR * simDtHours;
  if (maxStep < 0.1f) maxStep = 0.1f;

  float diff = target - g_fanAppliedPct;
  if (fabsf(diff) > maxStep) diff = (diff > 0) ? maxStep : -maxStep;

  setFanDutyApplied(g_fanAppliedPct + diff);
}

// VIRTUAL HOME LOAD MODEL
static const float ALWAYS_ON_W      = 120.0f;
static const float FRIDGE_ON_W      = 150.0f;
static const float LIGHTS_W         = 120.0f;
static const float HVAC_EXP         = 1.7f;

static const float HVAC_MAX_CHI_W   = 900.0f;
static const float HVAC_MAX_RIV_W   = 2500.0f;

static inline int simMinuteOfDay() {
  float hf = simHour_f;
  while (hf >= 24.0f) hf -= 24.0f;
  while (hf < 0.0f)   hf += 24.0f;
  int h = (int)floorf(hf);
  int m = (int)lroundf((hf - (float)h) * 60.0f);
  if (m >= 60) {
    m = 0;
    h = (h + 1) % 24;
  }
  return h * 60 + m;
}

static float computeLights_W(float scale) {
  int h = simHour;
  bool on = (tariffProfile == 1) ? (h >= 19 && h <= 23) : (h >= 17 && h <= 23);
  return on ? (LIGHTS_W * scale) : 0.0f;
}

static float computeFridge_W(float scale) {
  int mod = simMinuteOfDay() % 30;
  bool on = (mod < 10);
  return on ? (FRIDGE_ON_W * scale) : 0.0f;
}

static float computeMisc_W(float scale) {
  int h = simHour;
  float misc = 120.0f;
  if (h >= 6 && h <= 8)   misc = 250.0f;
  if (h >= 9 && h <= 16)  misc = 150.0f;
  if (h >= 17 && h <= 22) misc = 350.0f;
  return misc * scale;
}

static const float FAN_RPM_NOMINAL_MAX = 1800.0f;

static float fanSpeedFrac() {
  if (fanRPM > 50) return clampf((float)fanRPM / FAN_RPM_NOMINAL_MAX, 0.0f, 1.0f);
  return clampf(g_fanAppliedPct / 100.0f, 0.0f, 1.0f);
}

static float computeHvac_W(float scale) {
  float df = demandFactorByProfile(simHour);
  if (isPeakHour(simHour)) df = fmaxf(0.20f, df - 0.45f * thermalReserve);

  float hvacMax = (tariffProfile == 1) ? HVAC_MAX_RIV_W : HVAC_MAX_CHI_W;

  float s = fanSpeedFrac();
  float hvac = hvacMax * df * powf(s, HVAC_EXP);
  return hvac * scale;
}

static float computeFacilityLoad_W() {
  float scale = facilityScaleSafe();
  float base   = ALWAYS_ON_W * scale;
  float fridge = computeFridge_W(scale);
  float lights = computeLights_W(scale);
  float misc   = computeMisc_W(scale);
  float hvac   = computeHvac_W(scale);
  return base + fridge + lights + misc + hvac;
}

// ENERGY + COST
static double eGrid_kWh_acc  = 0.0;
static double eRenew_kWh_acc = 0.0;
static double eTotal_kWh_acc = 0.0;
static double costBaseline_acc = 0.0;
static double costActual_acc   = 0.0;

static double dayGrid_kWh_acc  = 0.0;
static double dayRenew_kWh_acc = 0.0;
static double dayEnergy_kWh_acc = 0.0;
static double dayCostBaseline_acc = 0.0;
static double dayCostActual_acc   = 0.0;
static int simDayCounter = 1;

void publishEnergyCostRounded() {
  energyGrid_kWh   = roundTo((float)eGrid_kWh_acc,  0.001f);
  energyRenew_kWh  = roundTo((float)eRenew_kWh_acc, 0.001f);
  energyTotal_kWh  = roundTo((float)eTotal_kWh_acc, 0.001f);

  costBaseline_USD = roundTo((float)costBaseline_acc, 0.001f);
  costActual_USD   = roundTo((float)costActual_acc,   0.001f);
  costSavings_USD  = roundTo(costBaseline_USD - costActual_USD, 0.001f);
}

void publishDayBucketRounded() {
  dayGrid_kWh  = roundTo((float)dayGrid_kWh_acc,  0.001f);
  dayRenew_kWh = roundTo((float)dayRenew_kWh_acc, 0.001f);
  dayEnergy_kWh = roundTo((float)dayEnergy_kWh_acc, 0.001f);

  dayCostBaseline_USD = roundTo((float)dayCostBaseline_acc, 0.001f);
  dayCostActual_USD   = roundTo((float)dayCostActual_acc,   0.001f);
  daySavings_USD      = roundTo(dayCostBaseline_USD - dayCostActual_USD, 0.001f);

  simDay = simDayCounter;
}

void resetEnergyAndCost() {
  eGrid_kWh_acc = eRenew_kWh_acc = eTotal_kWh_acc = 0.0;
  costBaseline_acc = costActual_acc = 0.0;

  dayGrid_kWh_acc = dayRenew_kWh_acc = dayEnergy_kWh_acc = 0.0;
  dayCostBaseline_acc = dayCostActual_acc = 0.0;

  simDayCounter = 1;
  simDay = simDayCounter;

  publishEnergyCostRounded();
  publishDayBucketRounded();
}

void finalizeSimDay() {
  publishDayBucketRounded();

  dayGrid_kWh_acc = dayRenew_kWh_acc = dayEnergy_kWh_acc = 0.0;
  dayCostBaseline_acc = dayCostActual_acc = 0.0;

  simDayCounter++;
  simDay = simDayCounter;
}

void accumulateEnergyCostSim(double simDtHours, float loadPowerW, float price) {
  if (simDtHours <= 0.0) return;

  float pW = loadPowerW;
  if (!isfinite(pW)) pW = 0;
  if (pW < 0) pW = -pW;

  double dE_kWh = ((double)pW * simDtHours) / 1000.0;
  if (dE_kWh < 0) dE_kWh = 0;

  costBaseline_acc += dE_kWh * (double)price;

  bool usingGrid  = relay1_on && !relay2_on;
  bool usingRenew = relay2_on && !relay1_on;

  if (usingGrid) {
    eGrid_kWh_acc += dE_kWh;
    costActual_acc += dE_kWh * (double)price;
  } else if (usingRenew) {
    eRenew_kWh_acc += dE_kWh;
  }
  eTotal_kWh_acc = eGrid_kWh_acc + eRenew_kWh_acc;

  dayCostBaseline_acc += dE_kWh * (double)price;
  dayEnergy_kWh_acc   += dE_kWh;

  if (usingGrid) {
    dayGrid_kWh_acc += dE_kWh;
    dayCostActual_acc += dE_kWh * (double)price;
  } else if (usingRenew) {
    dayRenew_kWh_acc += dE_kWh;
  }

  publishEnergyCostRounded();
}

float advanceSimClock(unsigned long dtMs) {
  if (!simRun) {
    updateSimTime12hCloud();
    return 0.0f;
  }

  float dt_min = (float)dtMs / 60000.0f;
  float spd = clampf(simSpeed_hoursPerMin, 0.0f, 120.0f);

  float simDtHours = spd * dt_min;
  simHour_f += simDtHours;

  while (simHour_f >= 24.0f) {
    simHour_f -= 24.0f;
    finalizeSimDay();
  }
  while (simHour_f < 0.0f) {
    simHour_f += 24.0f;
  }

  simHour = ((int)floor(simHour_f)) % 24;
  updateSimTime12hCloud();
  return simDtHours;
}

