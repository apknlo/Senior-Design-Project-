// INA226 HELPERS + I2C SCAN
bool ina226_write16(TwoWire &bus, uint8_t addr, uint8_t reg, uint16_t val) {
  bus.beginTransmission(addr);
  bus.write(reg);
  bus.write((uint8_t)(val >> 8));
  bus.write((uint8_t)(val & 0xFF));
  return (bus.endTransmission() == 0);
}

bool ina226_read16(TwoWire &bus, uint8_t addr, uint8_t reg, uint16_t &out) {
  bus.beginTransmission(addr);
  bus.write(reg);
  if (bus.endTransmission(false) != 0) return false;
  bus.requestFrom(addr, (uint8_t)2);
  if (bus.available() < 2) return false;
  uint16_t msb = bus.read();
  uint16_t lsb = bus.read();
  out = (msb << 8) | lsb;
  return true;
}

uint16_t ina226_calcCal(float shuntOhms) {
  float cal_f = 0.00512f / (CURRENT_LSB_A * shuntOhms);
  if (cal_f > 65535.0f) cal_f = 65535.0f;
  return (uint16_t)(cal_f + 0.5f);
}

bool ina226_init(TwoWire &bus, uint8_t addr, float shuntOhms, uint16_t &calOut) {
  if (!ina226_write16(bus, addr, REG_CONFIG, 0x4527)) return false;
  calOut = ina226_calcCal(shuntOhms);
  return ina226_write16(bus, addr, REG_CALIBRATION, calOut);
}

bool ina226_readVI(TwoWire &bus, uint8_t addr, float &busV, float &currentA) {
  uint16_t rawBus, rawCurU;
  if (!ina226_read16(bus, addr, REG_BUS_VOLT, rawBus)) return false;
  if (!ina226_read16(bus, addr, REG_CURRENT, rawCurU)) return false;
  busV = rawBus * 0.00125f;
  currentA = (int16_t)rawCurU * CURRENT_LSB_A;
  return true;
}

static void scanI2C() {
  Serial.println("\n=== I2C SCAN (Wire) ===");
  int found = 0;

  for (uint8_t addr = 1; addr < 127; addr++) {
    Wire.beginTransmission(addr);
    uint8_t err = Wire.endTransmission();
    if (err == 0) {
      Serial.print("  Found 0x");
      if (addr < 16) Serial.print("0");
      Serial.print(addr, HEX);

      uint16_t mid = 0, did = 0;
      bool okMid = ina226_read16(Wire, addr, REG_MANUF_ID, mid);
      bool okDid = ina226_read16(Wire, addr, REG_DIE_ID, did);
      if (okMid && okDid) {
        Serial.print("  (INA226? MID=0x");
        Serial.print(mid, HEX);
        Serial.print(" DID=0x");
        Serial.print(did, HEX);
        Serial.print(")");
      }
      Serial.println();
      found++;
    }
  }

  if (!found) Serial.println("  (none)");
}

// BATTERY SOC
float estimateSLA_SOC(float vBatt) {
  const float V_EMPTY = 11.8f;
  const float V_FULL  = 12.7f;
  float soc = (vBatt - V_EMPTY) * 100.0f / (V_FULL - V_EMPTY);
  return clampf(soc, 0.0f, 100.0f);
}

