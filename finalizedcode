  bool inPeak = isPeakHour(simHour);

  bool battOk = batteryOkForDischargeHyst(usingRenewNow);
  bool candidateRenew = (battOk && inPeak);

  double tSim = g_simTimeTotal_h;
  if (candidateRenew != lastCandidateRenew) {
    lastCandidateRenew = candidateRenew;
    candidateSinceSim_h = tSim;
  }

  if ((tSim - candidateSinceSim_h) >= DECISION_CONFIRM_SIM_H) {
    latchedWantRenew = candidateRenew;
  }

  relay1_on = !latchedWantRenew;
  relay2_on =  latchedWantRenew;

  const char* srcStr = latchedWantRenew ? "RENEW" : "GRID";
  emsState = String("AUTO | ") + getCityName() + " | " + rateBand +
             " | " + simTime12h +
             " | $" + String(price, 3) + "/kWh | SRC=" + srcStr +
             " | Load=" + String(lp, 0) + "W" +
             " | Fan=" + String(g_fanAppliedPct, 0) + "%";
}

// CLOUD CALLBACKS
void onRelay1OnChange() {
  if (bootHold) { relay1_on = false; relay2_on = false; return; }
  if (autoMode) return;
  if (relay1_on) relay2_on = false;
  applySourceRelaysSafe();
}

void onRelay2OnChange() {
  if (bootHold) { relay1_on = false; relay2_on = false; return; }
  if (autoMode) return;
  if (relay2_on) relay1_on = false;
  applySourceRelaysSafe();
}

void onTariffProfileChange() {
  if (tariffProfile < 0) tariffProfile = 0;
  if (tariffProfile > 1) tariffProfile = 1;
}

void onAutoModeChange() {}

void onSimRunChange() {
  lastTickMs = millis();
}

void onSimJumpHourChange() {
  if (simJumpHour < 0) simJumpHour = 0;
  if (simJumpHour > 23) simJumpHour = 23;
  applyJumpHour(simJumpHour);
  simJumpHour = simHour;
}

void onSimSpeedHoursPerMinChange() {
  simSpeed_hoursPerMin = clampf(simSpeed_hoursPerMin, 0.0f, 120.0f);
}


void onSolarSimEnableChange()  {}
void onSolarSimPctChange()     {}
void onSolarSimEnabledChange() {}

void onResetEnergyCostChange() {
  if (resetEnergyCost) {
    resetEnergyAndCost();
    resetEnergyCost = false;
  }
}

void onFaultResetChange() {
  if (faultReset) {
    clearFault();
    faultReset = false;
  }
}

void onAutoControlChange() {}

// SETUP / LOOP
void setup() {
  Serial.begin(115200);
  delay(200);

  initProperties();

  autoMode = false;
  relay1_on = false;
  relay2_on = false;

  zeroSolarTelemetry();

  ArduinoCloud.begin(ArduinoIoTPreferredConnection);

  bootStartMs = millis();
  bootHold = true;

  onFacilityScaleChange();

  pinMode(RELAY1_PIN, OUTPUT);
  pinMode(RELAY2_PIN, OUTPUT);
  allRelaysOff();
  trackAppliedRelays(millis(), false, false);

  Wire.begin(I2C0_SDA, I2C0_SCL);
  Wire.setClock(100000);

  scanI2C();

  ina226_init(Wire, INA_ADDR_LOAD, SHUNT_OHMS_LOAD, calLoad);
  ina226_init(Wire, INA_ADDR_GRID, SHUNT_OHMS_GRID, calGrid);
  ina226_init(Wire, INA_ADDR_BATT, SHUNT_OHMS_BATT, calBatt);

  ledcSetup(FAN_PWM_CH, FAN_PWM_FREQ, FAN_PWM_RES);
  ledcAttachPin(FAN_PWM_PIN, FAN_PWM_CH);
  setFanDutyApplied(fanDuty_pct);

  pinMode(FAN_TACH_PIN, INPUT);
  attachInterrupt(digitalPinToInterrupt(FAN_TACH_PIN), tachISR, FALLING);
  lastRpmSample = millis();

  applyJumpHour(simHour);
  updateSimTime12hCloud();

  lastTickMs = millis();
  lastSample = 0;

  emsState = "BOOT";
  rateBand = "";
  faultReason = "";
  faultActive = false;

  g_simTimeTotal_h = 0.0;
  latchedWantRenew = false;
  lastCandidateRenew = false;
  candidateSinceSim_h = 0.0;

  thermalReserve = 0.0f;

  resetEnergyAndCost();
}

void loop() {
  ArduinoCloud.update();

  unsigned long now = millis();

  if (bootHold) {
    if ((now - bootStartMs) < BOOT_HOLDOFF_MS) {
      autoMode = false;
      relay1_on = false;
      relay2_on = false;
      allRelaysOff();
      trackAppliedRelays(now, false, false);
      zeroSolarTelemetry();
      return;
    } else {
      bootHold = false;
    }
  }

  if (now - lastRpmSample >= RPM_SAMPLE_MS) {
    uint32_t pulses;
    noInterrupts();
    pulses = tachPulses;
    tachPulses = 0;
    interrupts();

    float seconds = (now - lastRpmSample) / 1000.0f;
    lastRpmSample = now;

    float rpm = (seconds > 0.0f)
      ? ((pulses / seconds) * (60.0f / (float)TACH_PULSES_PER_REV))
      : 0.0f;

    fanRPM = (int)(rpm + 0.5f);
  }

  if (now - lastSample >= SAMPLE_MS) {
    unsigned long prev = (lastTickMs == 0) ? now : lastTickMs;
    lastTickMs = now;
    unsigned long dtMs = now - prev;
    if (dtMs == 0) dtMs = SAMPLE_MS;
    lastSample = now;

    float simDtHours = advanceSimClock(dtMs);
    g_simTimeTotal_h += (double)simDtHours;

    float vLoad = 0, iLoad = 0;
    if (ina226_readVI(Wire, INA_ADDR_LOAD, vLoad, iLoad)) {
      loadVoltage_V = vLoad;
      loadCurrent_A = iLoad;
    }

    float vGrid = 0, iGrid = 0;
    if (ina226_readVI(Wire, INA_ADDR_GRID, vGrid, iGrid)) {
      gridVoltage_V = vGrid;
      gridCurrent_A = iGrid;
      gridPower_W   = (vGrid * fabs(iGrid)) * facilityScaleSafe();
      grid_bus_v    = vGrid;
    }

    float vBatt = 0, iBatt = 0;
    if (ina226_readVI(Wire, INA_ADDR_BATT, vBatt, iBatt)) {
      batteryVoltage_V = vBatt;
      batteryCurrent_A = iBatt;
      batteryPower_W   = (vBatt * fabs(iBatt)) * facilityScaleSafe();

      if (isnan(battV_filt)) battV_filt = vBatt;
      battV_filt = (1.0f - BATT_V_ALPHA) * battV_filt + BATT_V_ALPHA * vBatt;

      if (fabs(iBatt) <= BATT_REST_I_A) battSOC_hold = estimateSLA_SOC(battV_filt);
      batterySOC_pct = battSOC_hold;
    }

    // No solar INA in final hardware
    zeroSolarTelemetry();

    updateThermalReserve(simDtHours, fanSpeedFrac());
    updateFanAuto(simDtHours);

    loadPower_W = computeFacilityLoad_W();

    float price = getPrice(simHour);
    gridPrice_dperkWh = roundTo(price, 0.001f);
    rateBand = String(getBandName(simHour));

    if (!faultActive) {
      if (g_appliedR1 && g_appliedR2) {
        setFault("Both relays ON (tie risk)");
      }

      float iAbs = fabs(loadCurrent_A);
      if (iAbs > LOAD_OC_A) {
        if (g_overCurSinceMs == 0) g_overCurSinceMs = now;
        if ((now - g_overCurSinceMs) >= LOAD_OC_PERSIST_MS) {
          setFault("Load overcurrent");
        }
      } else {
        g_overCurSinceMs = 0;
      }
    }

    bool warnNoSource = false;
    if (!faultActive && !g_appliedR1 && !g_appliedR2) {
      if (g_bothOffSinceMs != 0 && (now - g_bothOffSinceMs) >= NO_SOURCE_WARN_MS) {
        if (fabs(loadCurrent_A) >= NO_SOURCE_I_A) {
          warnNoSource = true;
        }
      }
    }

    if (warnNoSource) setWarn("Load current present but no source selected");
    else clearWarn();

    if (faultActive) {
      emsState = "FAULT | " + faultReason;
      relay1_on = false;
      relay2_on = false;
    } else if (autoMode) {
      updateAutoDecision(loadPower_W);
    } else {
      String src = relay2_on ? "RENEW" : (relay1_on ? "GRID" : "OFF");
      emsState = "MANUAL | " + String(getCityName()) + " | " + rateBand +
                 " | " + simTime12h +
                 " | $" + String(price, 3) + "/kWh | SRC=" + src +
                 " | Load=" + String(loadPower_W, 0) + "W" +
                 " | Fan=" + String(g_fanAppliedPct, 0) + "%";
    }

    if (!faultActive && warnActive) {
      emsState = "WARN | " + warnReason + " | " + emsState;
    }

    applySourceRelaysSafe();

    if (!faultActive && simRun) {
      accumulateEnergyCostSim((double)simDtHours, loadPower_W, price);
    }
  }
}
